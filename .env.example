# ── Server ──────────────────────────────────────────────────
PORT=5000
CLIENT_ORIGIN=http://localhost:3000

# ── SMTP (nodemailer) ────────────────────────────────────────
# Fill these in with your Hostinger or other SMTP credentials
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@codeher.io
SMTP_PASS=your_email_password_here

# Email address that receives form submissions
CONTACT_EMAIL=hello@codeher.io

# ── BLS API (Bureau of Labor Statistics) ────────────────────
# Register free at https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here
